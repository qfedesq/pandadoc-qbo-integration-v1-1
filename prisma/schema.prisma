generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  PANDADOC
  QUICKBOOKS
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

enum InvoiceStatus {
  PAID
  OVERDUE
  OPEN
  PARTIALLY_PAID
}

enum SyncTrigger {
  USER
  CRON
  SYSTEM
}

enum SyncRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum SyncDirection {
  PULL
  PUSH
  BIDIRECTIONAL
}

enum AuthIdentityProvider {
  GOOGLE
}

enum UserRole {
  SELLER
  OPERATOR
  ADMIN
}

enum MarketplaceNode {
  PANDADOC
}

enum AccountingSystem {
  QUICKBOOKS
}

enum FactoringEligibilityStatus {
  ELIGIBLE
  INELIGIBLE
}

enum FactoringLifecycleStatus {
  IMPORTED
  ELIGIBLE
  PENDING_TERMS_ACCEPTANCE
  FUNDED
  REPAYMENT_PENDING
  REPAID
  DEFAULTED
}

enum SettlementMethod {
  USDC_WALLET
  ACH
  DEBIT_CARD
}

enum FactoringTransactionStatus {
  PENDING
  FUNDED
  DEFAULTED
  REPAID
  CANCELLED
}

enum CapitalSourceType {
  ARENA_STAFI_MANAGED_POOL
}

enum OnChainExecutionStatus {
  NOT_STARTED
  SIMULATED
  SETTLED
}

enum FactoringEventType {
  OFFER_GENERATED
  TERMS_ACCEPTED
  TRANSACTION_CREATED
  FUNDS_RESERVED
  CAPITAL_DISBURSED
  ARENA_SETTLEMENT_PREPARED
  STATUS_CHANGED
  REPAYMENT_PENDING
  REPAYMENT_RECORDED
  POOL_DISTRIBUTION_BOOKED
}

enum RiskTier {
  LOW
  MEDIUM
  HIGH
}

enum PoolTransactionType {
  FUNDING_DISBURSED
  REPAYMENT_RECEIVED
  YIELD_BOOKED
  PROTOCOL_FEE_BOOKED
}

enum LedgerOwnerType {
  SELLER
  POOL
  OPERATOR
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

model Organization {
  id                    String                  @id @default(cuid())
  name                  String
  slug                  String                  @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  users                 User[]
  connections           IntegrationConnection[]
  invoices              ImportedInvoice[]
  factoringOffers       FactoringOffer[]
  factoringTransactions FactoringTransaction[]
  auditEvents           FactoringEventLog[]
  syncRuns              SyncRun[]
  documentLinks         DocumentInvoiceLink[]
  poolTransactions      PoolTransaction[]
  walletLedgers         WalletLedger[]

  @@map("organizations")
}

model User {
  id             String                  @id @default(cuid())
  organizationId String?
  email          String                  @unique
  name           String?
  role           UserRole                @default(SELLER)
  passwordHash   String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  sessions       AppSession[]
  oauthStates    OAuthState[]
  authIdentities UserIdentity[]
  connections    IntegrationConnection[]
  invoices       ImportedInvoice[]
  webhookEvents  WebhookEventLog[]
  syncRuns       SyncRun[]
  documentLinks  DocumentInvoiceLink[]
  factoringOffers FactoringOffer[]
  factoringTransactions FactoringTransaction[]
  factoringEvents FactoringEventLog[]
  organization   Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([role])
  @@map("users")
}

model AppSession {
  id               String   @id @default(cuid())
  userId           String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  lastSeenAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("app_sessions")
}

model OAuthState {
  id          String    @id @default(cuid())
  userId      String
  provider    Provider
  state       String    @unique
  redirectTo  String?
  codeVerifier String?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
  @@index([expiresAt])
  @@map("oauth_states")
}

model AuthLoginState {
  id         String               @id @default(cuid())
  provider   AuthIdentityProvider
  state      String               @unique
  redirectTo String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime             @default(now())

  @@index([provider, expiresAt])
  @@map("auth_login_states")
}

model UserIdentity {
  id             String               @id @default(cuid())
  userId         String
  provider       AuthIdentityProvider
  providerUserId String
  email          String?
  displayName    String?
  avatarUrl      String?
  profile        Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
  @@map("user_identities")
}

model IntegrationConnection {
  id                  String                  @id @default(cuid())
  userId              String
  organizationId      String?
  provider            Provider
  status              IntegrationStatus       @default(DISCONNECTED)
  displayName         String?
  externalAccountId   String?
  externalAccountName String?
  scopes              String[]
  lastSyncAt          DateTime?
  lastError           String?
  metadata            Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  token               OAuthToken?
  quickBooksCompany   QuickBooksCompany?
  importedInvoices    ImportedInvoice[]
  webhookEvents       WebhookEventLog[]
  syncRuns            SyncRun[]
  documentLinks       DocumentInvoiceLink[]   @relation("PandaDocDocumentLinks")

  @@unique([userId, provider])
  @@index([provider, status])
  @@index([organizationId, provider, status])
  @@map("accounting_connections")
}

model OAuthToken {
  id                     String   @id @default(cuid())
  connectionId           String   @unique
  accessTokenEncrypted   String
  refreshTokenEncrypted  String
  accessTokenExpiresAt   DateTime
  refreshTokenExpiresAt  DateTime?
  tokenType              String
  scope                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  connection             IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([accessTokenExpiresAt])
  @@map("oauth_tokens")
}

model QuickBooksCompany {
  id          String   @id @default(cuid())
  connectionId String  @unique
  realmId     String   @unique
  companyName String?
  country     String?
  currency    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  connection  IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  invoices    ImportedInvoice[]

  @@map("quickbooks_companies")
}

model ImportedInvoice {
  id                 String        @id @default(cuid())
  userId             String
  organizationId     String?
  connectionId       String
  quickBooksCompanyId String?
  provider           Provider
  providerInvoiceId  String
  docNumber          String?
  totalAmount        Decimal       @db.Decimal(18, 2)
  balanceAmount      Decimal       @db.Decimal(18, 2)
  currency           String?
  dueDate            DateTime?
  issueDate          DateTime?
  txnDate            DateTime?
  createdTime        DateTime?
  updatedTime        DateTime?
  counterpartyName   String
  counterpartyEmail  String?
  normalizedStatus   InvoiceStatus
  factoringLifecycleStatus FactoringLifecycleStatus @default(IMPORTED)
  fundedAt           DateTime?
  repaidAt           DateTime?
  rawPayload         Json
  lastSyncedAt       DateTime
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  connection         IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  quickBooksCompany  QuickBooksCompany? @relation(fields: [quickBooksCompanyId], references: [id], onDelete: SetNull)
  documentLinks      DocumentInvoiceLink[]
  factoringOffer     FactoringOffer?
  factoringTransactions FactoringTransaction[]
  factoringEvents    FactoringEventLog[]

  @@unique([connectionId, providerInvoiceId])
  @@index([userId, normalizedStatus])
  @@index([userId, factoringLifecycleStatus])
  @@index([userId, dueDate, lastSyncedAt])
  @@index([connectionId, lastSyncedAt])
  @@index([counterpartyName])
  @@map("invoices")
}

model WebhookEventLog {
  id                 String   @id @default(cuid())
  provider           Provider
  userId             String?
  connectionId       String?
  externalEventId    String?
  eventType          String?
  signatureValidated Boolean?
  deliveryKey        String?
  payloadHash        String
  headers            Json
  payload            Json
  processedAt        DateTime?
  createdAt          DateTime @default(now())
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  connection         IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([provider, payloadHash])
  @@index([provider, createdAt])
  @@map("webhook_event_logs")
}

model SyncRun {
  id             String        @id @default(cuid())
  userId         String?
  organizationId String?
  connectionId   String?
  provider       Provider
  trigger        SyncTrigger
  status         SyncRunStatus
  fetchedCount   Int           @default(0)
  processedCount Int           @default(0)
  upsertedCount  Int           @default(0)
  skippedCount   Int           @default(0)
  errorCount     Int           @default(0)
  cursor         String?
  errorMessage   String?
  metrics        Json?
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  connection     IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([provider, startedAt])
  @@map("sync_runs")
}

model MetricCounter {
  id         String   @id @default(cuid())
  name       String
  scope      String
  count      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, scope])
  @@map("metric_counters")
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  keyHash     String
  bucketStart DateTime
  expiresAt   DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([keyHash, bucketStart])
  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

model DocumentInvoiceLink {
  id                    String        @id @default(cuid())
  userId                String
  organizationId        String?
  importedInvoiceId     String
  pandadocConnectionId  String?
  pandadocDocumentId    String
  documentName          String?
  pandadocDocumentStatus String?
  autoSend              Boolean       @default(false)
  sentAt                DateTime?
  lastSyncedAt          DateTime?
  lastError             String?
  syncDirection         SyncDirection @default(BIDIRECTIONAL)
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  importedInvoice       ImportedInvoice @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  pandadocConnection    IntegrationConnection? @relation("PandaDocDocumentLinks", fields: [pandadocConnectionId], references: [id], onDelete: SetNull)

  @@unique([userId, pandadocDocumentId])
  @@unique([userId, importedInvoiceId])
  @@map("document_invoice_links")
}

model CapitalSource {
  id                String           @id @default(cuid())
  key               String           @unique
  name              String
  marketplaceNode   MarketplaceNode
  type              CapitalSourceType
  network           String
  currency          String
  operatorWallet    String?
  liquiditySnapshot Decimal?         @db.Decimal(18, 2)
  totalLiquidity    Decimal          @default(0) @db.Decimal(18, 2)
  availableLiquidity Decimal         @default(0) @db.Decimal(18, 2)
  deployedLiquidity Decimal          @default(0) @db.Decimal(18, 2)
  accruedYield      Decimal          @default(0) @db.Decimal(18, 2)
  protocolFeesCollected Decimal      @default(0) @db.Decimal(18, 2)
  targetAdvanceRateBps Int           @default(9000)
  operatorFeeBps    Int              @default(50)
  isActive          Boolean          @default(true)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  offers            FactoringOffer[]
  transactions      FactoringTransaction[]
  poolTransactions  PoolTransaction[]
  walletLedgers     WalletLedger[]

  @@index([marketplaceNode, type, isActive])
  @@map("liquidity_pools")
}

model FactoringOffer {
  id                   String                     @id @default(cuid())
  userId               String
  organizationId       String?
  importedInvoiceId    String                     @unique
  capitalSourceId      String
  marketplaceNode      MarketplaceNode
  accountingSystem     AccountingSystem
  eligibilityStatus    FactoringEligibilityStatus
  ineligibilityReason  String?
  grossAmount          Decimal                    @db.Decimal(18, 2)
  advanceRateBps       Int
  advanceAmount        Decimal                    @db.Decimal(18, 2)
  discountRateBps      Int
  discountAmount       Decimal                    @db.Decimal(18, 2)
  operatorFeeBps       Int
  operatorFeeAmount    Decimal                    @db.Decimal(18, 2)
  netProceeds          Decimal                    @db.Decimal(18, 2)
  expectedRepaymentAmount Decimal                 @db.Decimal(18, 2)
  expectedMaturityDate DateTime?
  riskTier             RiskTier
  settlementCurrency   String
  settlementTimeSummary String
  termsSnapshot        Json
  generatedAt          DateTime                   @default(now())
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  importedInvoice      ImportedInvoice            @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  capitalSource        CapitalSource              @relation(fields: [capitalSourceId], references: [id], onDelete: Restrict)
  transactions         FactoringTransaction[]

  @@index([userId, eligibilityStatus])
  @@map("factoring_offers")
}

model FactoringTransaction {
  id                         String                     @id @default(cuid())
  transactionReference       String                     @unique
  userId                     String
  organizationId             String?
  importedInvoiceId          String
  factoringOfferId           String?
  capitalSourceId            String
  marketplaceNode            MarketplaceNode
  accountingSystem           AccountingSystem
  status                     FactoringTransactionStatus @default(PENDING)
  settlementMethod           SettlementMethod
  settlementDestinationMasked String
  sellerWalletAddress        String?
  invoiceCurrency            String?
  settlementCurrency         String
  grossAmount                Decimal                    @db.Decimal(18, 2)
  advanceRateBps             Int
  advanceAmount              Decimal                    @db.Decimal(18, 2)
  principalAmount            Decimal                    @db.Decimal(18, 2)
  discountRateBps            Int
  discountAmount             Decimal                    @db.Decimal(18, 2)
  operatorFeeBps             Int
  operatorFeeAmount          Decimal                    @db.Decimal(18, 2)
  poolYieldAmount            Decimal                    @db.Decimal(18, 2)
  netProceeds                Decimal                    @db.Decimal(18, 2)
  expectedRepaymentAmount    Decimal                    @db.Decimal(18, 2)
  maturityDate               DateTime?
  riskTier                   RiskTier
  settlementTimeLabel        String
  termsAcceptedAt            DateTime
  reservedAt                 DateTime?
  fundedAt                   DateTime?
  repaidAt                   DateTime?
  operatorWallet             String?
  arenaSettlementReference   String?
  onChainExecutionStatus     OnChainExecutionStatus     @default(NOT_STARTED)
  metadata                   Json?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  user                       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization               Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  importedInvoice            ImportedInvoice            @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  factoringOffer             FactoringOffer?            @relation(fields: [factoringOfferId], references: [id], onDelete: SetNull)
  capitalSource              CapitalSource              @relation(fields: [capitalSourceId], references: [id], onDelete: Restrict)
  events                     FactoringEventLog[]
  poolTransactions           PoolTransaction[]
  walletLedgers              WalletLedger[]

  @@index([userId, status, createdAt])
  @@index([userId, createdAt])
  @@index([importedInvoiceId, status])
  @@map("factoring_positions")
}

model FactoringEventLog {
  id                    String                     @id @default(cuid())
  userId                String
  organizationId        String?
  importedInvoiceId     String
  factoringTransactionId String?
  eventType             FactoringEventType
  statusFrom            FactoringTransactionStatus?
  statusTo              FactoringTransactionStatus?
  message               String
  metadata              Json?
  createdAt             DateTime                   @default(now())
  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  importedInvoice       ImportedInvoice            @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  factoringTransaction  FactoringTransaction?      @relation(fields: [factoringTransactionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, eventType, createdAt])
  @@index([factoringTransactionId, createdAt])
  @@map("audit_events")
}

model PoolTransaction {
  id                    String                     @id @default(cuid())
  organizationId        String?
  capitalSourceId       String
  factoringTransactionId String?
  transactionType       PoolTransactionType
  currency              String
  amount                Decimal                    @db.Decimal(18, 2)
  principalAmount       Decimal                    @db.Decimal(18, 2)
  yieldAmount           Decimal                    @db.Decimal(18, 2)
  feeAmount             Decimal                    @db.Decimal(18, 2)
  metadata              Json?
  createdAt             DateTime                   @default(now())
  organization          Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  capitalSource         CapitalSource              @relation(fields: [capitalSourceId], references: [id], onDelete: Cascade)
  factoringTransaction  FactoringTransaction?      @relation(fields: [factoringTransactionId], references: [id], onDelete: SetNull)

  @@index([capitalSourceId, transactionType, createdAt])
  @@index([capitalSourceId, createdAt])
  @@map("pool_transactions")
}

model WalletLedger {
  id                    String                     @id @default(cuid())
  organizationId        String?
  capitalSourceId       String?
  factoringTransactionId String?
  ownerType             LedgerOwnerType
  ownerId               String
  entryType             String
  direction             LedgerDirection
  currency              String
  amount                Decimal                    @db.Decimal(18, 2)
  balanceAfter          Decimal                    @db.Decimal(18, 2)
  description           String
  metadata              Json?
  createdAt             DateTime                   @default(now())
  organization          Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  capitalSource         CapitalSource?             @relation(fields: [capitalSourceId], references: [id], onDelete: SetNull)
  factoringTransaction  FactoringTransaction?      @relation(fields: [factoringTransactionId], references: [id], onDelete: SetNull)

  @@index([ownerType, ownerId, createdAt])
  @@index([capitalSourceId, createdAt])
  @@map("wallet_ledgers")
}
