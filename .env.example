NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pandadoc_qbo?schema=public

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
SEED_DEMO_DATA=true

SESSION_COOKIE_NAME=pandadoc_qbo_session
SESSION_TTL_HOURS=168
OUTBOUND_HTTP_TIMEOUT_MS=15000
INVOICE_SYNC_ENABLED=true
INVOICE_SYNC_INTERVAL_MINUTES=60
QUICKBOOKS_MODE=mock
FACTORING_BASE_DISCOUNT_BPS=450
FACTORING_PARTIAL_PAYMENT_DISCOUNT_BPS=325
FACTORING_ADVANCE_RATE_BPS=9000
FACTORING_PROTOCOL_FEE_BPS=50
FACTORING_MIN_INVOICE_AMOUNT=500
FACTORING_MIN_NET_PROCEEDS=250
ARENA_STAFI_POOL_NAME=Protofire Arena StaFi Managed Pool
ARENA_STAFI_NETWORK=Arena StaFi
ARENA_STAFI_OPERATOR_WALLET=0xProtofireOperatorWalletDemo
ARENA_STAFI_LIQUIDITY_SNAPSHOT=500000

TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# INTERNAL_SYNC_SECRET protects POST /api/invoices/sync for internal workers or external schedulers
INTERNAL_SYNC_SECRET=replace-with-a-long-random-string
# CRON_SECRET protects GET /api/cron/invoices-sync when using Vercel Cron
CRON_SECRET=replace-with-a-long-random-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_SCOPES=openid email profile
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_ALLOWED_EMAIL_DOMAINS=gmail.com,googlemail.com

PANDADOC_CLIENT_ID=
PANDADOC_CLIENT_SECRET=
PANDADOC_REDIRECT_URI=http://localhost:3000/api/oauth/pandadoc/callback
PANDADOC_SCOPES=read+write
PANDADOC_AUTH_URL=https://app.pandadoc.com/oauth2/authorize
PANDADOC_TOKEN_URL=https://api.pandadoc.com/oauth2/access_token
PANDADOC_API_BASE_URL=https://api.pandadoc.com
PANDADOC_TEMPLATE_UUID=
PANDADOC_RECIPIENT_ROLE=Client
PANDADOC_DOCUMENT_NAME_PREFIX=Invoice
PANDADOC_SEND_ON_IMPORT=false
PANDADOC_WEBHOOK_SHARED_SECRET=

QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/oauth/quickbooks/callback
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
QUICKBOOKS_ENV=sandbox
QUICKBOOKS_AUTH_URL=https://appcenter.intuit.com/connect/oauth2
QUICKBOOKS_TOKEN_URL=https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer
QUICKBOOKS_MINOR_VERSION=75
